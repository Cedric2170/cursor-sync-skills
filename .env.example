# ------------------------------------------------------------
# Configuration cursorsync
# Copiez ce fichier en .env puis adaptez les valeurs.
# ------------------------------------------------------------

# ------------------------------------------------------------
# GIT Parameters
# ------------------------------------------------------------
# Branche Git utilisee pour pull/push
SKILLS_BRANCH="main"
# URL du depot skills (A MODIFIER)
SKILLS_ORIGIN_URL="git@github.com:VOTRE-ORG/VOTRE-REPO.git"

# ------------------------------------------------------------
# Cursor Parameters (Default values)
# ------------------------------------------------------------
# Repertoire Cursor local
CURSOR_DIR="$HOME/.cursor"
# Repertoire local du clone synchronise
CURSOR_SKILLS_SYNC_DIR="$HOME/.skills-sync"
# Purge automatique de ~/.cursor/.git pendant install_host.sh
# 0 = non (par defaut), 1 = oui
CURSOR_PURGE_OLD_CURSOR_GIT="0"
# Ignore le push pendant install_host.sh
# 0 = non (par defaut), 1 = oui
CURSOR_INSTALL_SKIP_PUSH="0"
# Fichier shell cible pour l'ajout des alias
# Laisser vide pour auto-detection (~/.zshrc ou ~/.bashrc)
SHELL_RC=""
