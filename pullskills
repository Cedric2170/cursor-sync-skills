#!/usr/bin/env bash
set -euo pipefail

SYNC_DIR="${CURSOR_SKILLS_SYNC_DIR:-$HOME/.skills-sync}"
BRANCH="${SKILLS_BRANCH:-main}"
CURSOR_DIR="${CURSOR_DIR:-$HOME/.cursor}"

if [[ ! -d "$SYNC_DIR/.git" ]]; then
  echo "Depot skills introuvable: $SYNC_DIR — lancez install_host.sh"
  exit 1
fi

git -C "$SYNC_DIR" fetch origin
git -C "$SYNC_DIR" pull --rebase --autostash origin "$BRANCH"

# Fusion clone -> local apres pull (sans --delete).
sync_repo_to_cursor() {
  local s="$1" c="$2"
  if [[ -d "$s" ]]; then
    mkdir -p "$c"
    rsync -a "$s/" "$c/"
  fi
}
sync_repo_to_cursor "$SYNC_DIR/skills" "$CURSOR_DIR/skills"
sync_repo_to_cursor "$SYNC_DIR/roles" "$CURSOR_DIR/rules"
sync_repo_to_cursor "$SYNC_DIR/subagent" "$CURSOR_DIR/subagent"
sync_repo_to_cursor "$SYNC_DIR/hooks" "$CURSOR_DIR/hooks"

echo "pullskills OK ($BRANCH) — HEAD $(git -C "$SYNC_DIR" rev-parse --short HEAD)."
