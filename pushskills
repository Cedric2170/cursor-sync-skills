#!/usr/bin/env bash
set -euo pipefail

SYNC_DIR="${CURSOR_SKILLS_SYNC_DIR:-$HOME/.skills-sync}"
BRANCH="${SKILLS_BRANCH:-main}"
CURSOR_DIR="${CURSOR_DIR:-$HOME/.cursor}"

if [[ ! -d "$SYNC_DIR/.git" ]]; then
  echo "Depot skills introuvable: $SYNC_DIR — lancez install_host.sh"
  exit 1
fi

# Repertoires fusionnes: copier ~/.cursor -> skills-sync avant commit (sans --delete dans le depot)
sync_cursor_to_repo() {
  local c="$1" s="$2"
  if [[ -d "$c" ]]; then
    mkdir -p "$s"
    rsync -a "$c/" "$s/"
  fi
}
sync_cursor_to_repo "$CURSOR_DIR/skills" "$SYNC_DIR/skills"
sync_cursor_to_repo "$CURSOR_DIR/rules" "$SYNC_DIR/roles"
sync_cursor_to_repo "$CURSOR_DIR/subagent" "$SYNC_DIR/subagent"
sync_cursor_to_repo "$CURSOR_DIR/hooks" "$SYNC_DIR/hooks"

git -C "$SYNC_DIR" add -A

if git -C "$SYNC_DIR" diff --staged --quiet && git -C "$SYNC_DIR" diff --quiet; then
  echo "Rien a commiter."
  exit 0
fi

host="$(hostname -s 2>/dev/null || hostname)"
host="${host//[^a-zA-Z0-9._-]/_}"
msg="${host}-sync-$(date -u +%Y%m%d-%H%M%S)"

git -C "$SYNC_DIR" commit -m "$msg"
git -C "$SYNC_DIR" push origin "HEAD:${BRANCH}"
echo "pushskills OK: $msg"
