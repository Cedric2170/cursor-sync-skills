#!/usr/bin/env bash
set -euo pipefail

SYNC_DIR="${CURSOR_SKILLS_SYNC_DIR:-$HOME/.skills-sync}"
BRANCH="${SKILLS_BRANCH:-main}"

if [[ ! -d "$SYNC_DIR/.git" ]]; then
  echo "Depot skills introuvable: $SYNC_DIR — lancez install_host.sh"
  exit 1
fi

# Integrer d abord le remote pour eviter les rejets non-fast-forward.
git -C "$SYNC_DIR" fetch origin
git -C "$SYNC_DIR" pull --rebase --autostash origin "$BRANCH"

git -C "$SYNC_DIR" add -A -- skills scripts

msg=""
if ! git -C "$SYNC_DIR" diff --staged --quiet; then
  host="$(hostname -s 2>/dev/null || hostname)"
  host="${host//[^a-zA-Z0-9._-]/_}"
  msg="${host}-sync-$(date -u +%Y%m%d-%H%M%S)"
  git -C "$SYNC_DIR" commit -m "$msg"
fi

head_short="$(git -C "$SYNC_DIR" rev-parse --short HEAD)"
origin_url="$(git -C "$SYNC_DIR" remote get-url origin 2>/dev/null || echo "origin")"

echo "pushskills: envoi git vers origin/${BRANCH} (HEAD ${head_short})..."
echo "  distant: ${origin_url}"

# Retry unique en cas de concurrence entre pull et push.
if ! git -C "$SYNC_DIR" push --progress origin "HEAD:${BRANCH}"; then
  echo "pushskills: push rejete, tentative auto: pull --rebase puis re-push..." >&2
  git -C "$SYNC_DIR" pull --rebase --autostash origin "$BRANCH"
  git -C "$SYNC_DIR" push --progress origin "HEAD:${BRANCH}"
fi

if [[ -n "$msg" ]]; then
  echo "pushskills OK — commit cree et pousse: ${msg} (branche ${BRANCH}, ${head_short})."
else
  echo "pushskills OK — push effectue vers origin (branche ${BRANCH}, ${head_short}); pas de nouveau commit local cette fois."
fi
