#!/usr/bin/env bash
set -euo pipefail

SELF_PATH="${BASH_SOURCE[0]:-$0}"
SELF_DIR="$(cd "$(dirname "$SELF_PATH")" && pwd)"
ENV_FILE_PATH="${ENV_FILE:-$SELF_DIR/.env}"
if [[ -f "$ENV_FILE_PATH" ]]; then
  set -a
  # shellcheck disable=SC1090
  source "$ENV_FILE_PATH"
  set +a
fi

SYNC_DIR="${CURSOR_SKILLS_SYNC_DIR:-$HOME/.skills-sync}"
BRANCH="${SKILLS_BRANCH:-main}"
CURSOR_DIR="${CURSOR_DIR:-$HOME/.cursor}"

if [[ ! -d "$SYNC_DIR/.git" ]]; then
  echo "Depot skills introuvable: $SYNC_DIR — lancez install_host.sh"
  exit 1
fi

check_symlink() {
  local link_path="$1"
  local expected_target="$2"

  if [[ ! -L "$link_path" ]]; then
    echo "Erreur: lien manquant ou invalide: $link_path"
    echo "Attendu: $link_path -> $expected_target"
    echo "Relancez install_host.sh pour reparer."
    exit 1
  fi

  local current_target
  current_target="$(readlink "$link_path")"
  if [[ "$current_target" != "$expected_target" ]]; then
    echo "Erreur: lien incorrect: $link_path -> $current_target"
    echo "Attendu: $link_path -> $expected_target"
    echo "Relancez install_host.sh pour reparer."
    exit 1
  fi
}

# Verifie que le mode symlink-only est bien en place.
check_symlink "$CURSOR_DIR/skills" "$SYNC_DIR/skills"
check_symlink "$CURSOR_DIR/rules" "$SYNC_DIR/roles"
check_symlink "$CURSOR_DIR/subagent" "$SYNC_DIR/subagent"
check_symlink "$CURSOR_DIR/hooks" "$SYNC_DIR/hooks"

# Integrer d abord le remote pour eviter les rejets non-fast-forward.
git -C "$SYNC_DIR" fetch origin
git -C "$SYNC_DIR" pull --rebase --autostash origin "$BRANCH"

# Mode symlink-only: les changements faits sous ~/.cursor/* sont
# directement visibles dans $SYNC_DIR via les liens symboliques.

git -C "$SYNC_DIR" add -A -- skills roles subagent hooks

msg=""
if ! git -C "$SYNC_DIR" diff --staged --quiet; then
  host="$(hostname -s 2>/dev/null || hostname)"
  host="${host//[^a-zA-Z0-9._-]/_}"
  msg="${host}-sync-$(date -u +%Y%m%d-%H%M%S)"
  git -C "$SYNC_DIR" commit -m "$msg"
fi

head_short="$(git -C "$SYNC_DIR" rev-parse --short HEAD)"
origin_url="$(git -C "$SYNC_DIR" remote get-url origin 2>/dev/null || echo "origin")"

echo "pushskills: envoi git vers origin/${BRANCH} (HEAD ${head_short})..."
echo "  distant: ${origin_url}"

# Tentative unique en cas de concurrence entre pull et push.
if ! git -C "$SYNC_DIR" push --progress origin "HEAD:${BRANCH}"; then
  echo "pushskills: push rejete, tentative auto: pull --rebase puis re-push..." >&2
  git -C "$SYNC_DIR" pull --rebase --autostash origin "$BRANCH"
  git -C "$SYNC_DIR" push --progress origin "HEAD:${BRANCH}"
fi

if [[ -n "$msg" ]]; then
  echo "pushskills OK — commit cree et pousse: ${msg} (branche ${BRANCH}, ${head_short})."
else
  echo "pushskills OK — push effectue vers origin (branche ${BRANCH}, ${head_short}); pas de nouveau commit local cette fois."
fi
