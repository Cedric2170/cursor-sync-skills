#!/usr/bin/env bash
set -euo pipefail

SYNC_DIR="${CURSOR_SKILLS_SYNC_DIR:-$HOME/.skills-sync}"
BRANCH="${SKILLS_BRANCH:-main}"
CURSOR_DIR="${CURSOR_DIR:-$HOME/.cursor}"
# Par defaut: rsync --delete pour que les suppressions dans ~/.cursor se reflètent dans le clone et dans Git.
# Mettre CURSOR_SKILLS_RSYNC_NO_DELETE=1 pour ne jamais effacer dans ~/.skills-sync des chemins absents de ~/.cursor.
RSYNC_EXTRA=()
if [[ "${CURSOR_SKILLS_RSYNC_NO_DELETE:-0}" != "1" ]]; then
  RSYNC_EXTRA=(--delete)
fi

if [[ ! -d "$SYNC_DIR/.git" ]]; then
  echo "Depot skills introuvable: $SYNC_DIR — lancez install_host.sh"
  exit 1
fi

# Repertoires fusionnes: copier ~/.cursor -> skills-sync avant commit (--delete sauf opt-out)
sync_cursor_to_repo() {
  local c="$1" s="$2"
  if [[ -d "$c" ]]; then
    mkdir -p "$s"
    rsync -a "${RSYNC_EXTRA[@]}" "$c/" "$s/"
    if [[ "${PUSHSKILLS_VERBOSE:-0}" == 1 ]]; then
      local n
      n="$(find "$c" -type f 2>/dev/null | wc -l | tr -d ' ')"
      echo "pushskills [verbose]: ${n} fichier(s) depuis $(printf '%q' "$c") vers $(printf '%q' "$s")" >&2
    fi
  else
    if [[ "${PUSHSKILLS_VERBOSE:-0}" == 1 ]]; then
      echo "pushskills [verbose]: repertoire absent, pas de copie: $(printf '%q' "$c")" >&2
    fi
  fi
}
sync_cursor_to_repo "$CURSOR_DIR/skills" "$SYNC_DIR/skills"
sync_cursor_to_repo "$CURSOR_DIR/rules" "$SYNC_DIR/roles"
sync_cursor_to_repo "$CURSOR_DIR/subagent" "$SYNC_DIR/subagent"
sync_cursor_to_repo "$CURSOR_DIR/hooks" "$SYNC_DIR/hooks"

git -C "$SYNC_DIR" add -A

# --porcelain=v1 reflete correctement les ajouts (git diff --staged --quiet peut laisser passer des cas)
porcelain="$(git -C "$SYNC_DIR" status --porcelain=v1)"
# Fichiers presents sur le disque mais exclus de l'index — avertir seulement si ce n'est pas du bruit systeme (.DS_Store, etc.)
ignored_raw="$(
  git -C "$SYNC_DIR" ls-files -o -i --exclude-standard -- skills roles subagent hooks 2>/dev/null || true
)"
ignored_warn="$(echo "$ignored_raw" | grep -Ev '(^|/)(\.DS_Store|Thumbs\.db|desktop\.ini)$|\.(swp|tmp)$|~$' | head -50 || true)"

if [[ -n "$ignored_warn" ]]; then
  echo "Avertissement: fichiers ignores par Git sous skills/, roles/, subagent/ ou hooks/ — ils ne seront pas commites." >&2
  echo "$ignored_warn" | head -15 | sed 's/^/  /' >&2
  echo "  Verifiez .gitignore et la config globale (ex. core.excludesfile)." >&2
  echo "  Diagnostic: PUSHSKILLS_VERBOSE=1 pushskills" >&2
elif [[ "${PUSHSKILLS_VERBOSE:-0}" == 1 && -n "$ignored_raw" ]]; then
  echo "pushskills [verbose]: fichiers ignores uniquement \"bruit\" systeme (.DS_Store, etc.) — rien a signaler." >&2
fi

msg=""
if [[ -n "$porcelain" ]]; then
  host="$(hostname -s 2>/dev/null || hostname)"
  host="${host//[^a-zA-Z0-9._-]/_}"
  msg="${host}-sync-$(date -u +%Y%m%d-%H%M%S)"
  git -C "$SYNC_DIR" commit -m "$msg"
fi

head_short="$(git -C "$SYNC_DIR" rev-parse --short HEAD)"
origin_url="$(git -C "$SYNC_DIR" remote get-url origin 2>/dev/null || echo "origin")"

# Pousse aussi les commits deja locaux (--progress: sortie meme si stderr n'est pas un terminal)
echo "pushskills: envoi git vers origin/${BRANCH} (HEAD ${head_short})..."
echo "  distant: ${origin_url}"
git -C "$SYNC_DIR" push --progress origin "HEAD:${BRANCH}"

if [[ -n "$msg" ]]; then
  echo "pushskills OK — commit cree et pousse: ${msg} (branche ${BRANCH}, ${head_short})."
else
  echo "pushskills OK — push effectue vers GitLab (branche ${BRANCH}, ${head_short}); pas de nouveau commit local cette fois."
  if [[ "${PUSHSKILLS_VERBOSE:-0}" == 1 ]]; then
    echo "pushskills [verbose]: CURSOR_DIR=$(printf '%q' "$CURSOR_DIR") SYNC_DIR=$(printf '%q' "$SYNC_DIR")" >&2
  fi
fi
